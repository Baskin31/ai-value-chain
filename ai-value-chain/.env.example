# Optional: GitHub raw content base URL for on-demand YAML refresh
# Example: https://raw.githubusercontent.com/yourname/yourrepo/main/ai-value-chain
VITE_DATA_SOURCE_URL=

# Optional: Market data API key (Twelve Data or Polygon.io)
# If not set, app uses Yahoo Finance unofficial endpoint (no key needed)
VITE_MARKET_API_KEY=
